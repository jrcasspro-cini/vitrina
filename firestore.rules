rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is the platform administrator.
    // Admin sa prihlasuje cez normálny Firebase Auth (email + heslo).
    // Predtým existoval aj alias 'admin@vitrina.app' s hardcoded heslom
    // 'vitrina2026' v kóde — odstránené kvôli tomu, že heslo bolo verejné
    // na GitHube (ktokoľvek si mohol nahodiť admin@vitrina.app účet).
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'jrcasspro@gmail.com';
    }

    // Helper to check if user is the owner of the given store
    function isStoreOwner(storeId) {
      return request.auth != null && (
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
      );
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isAdmin() || (
        request.auth != null && resource.data.ownerId == request.auth.uid
      );
    }

    match /items/{itemId} {
      allow read: if true;
      allow create: if isAdmin() || isStoreOwner(request.resource.data.storeId);
      allow update, delete: if isAdmin() || isStoreOwner(resource.data.storeId);
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || isStoreOwner(resource.data.storeId);
    }

    // Config: čítanie verejné (aby ToS/Privacy stránky videli aj neprihlásení),
    // zápis iba admin. Predtym bolo `allow read, write: if true` — kritická
    // bezpečnostná diera (ktokoľvek mohol prepísať konfiguráciu).
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Faktúry za predplatné (Zavio → predajca). Vystavuje iba admin (pri
    // aktivácii plánu), predajca si vie prečítať len svoje vlastné faktúry.
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (
        request.auth != null && isStoreOwner(resource.data.storeId)
      );
      allow create, update, delete: if isAdmin();
    }
  }
}
